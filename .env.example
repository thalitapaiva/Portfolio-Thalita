# Database
DATABASE_URL=postgresql://portfolio:portfolio@localhost:5432/portfolio_thalita?schema=public

# Apps
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api
PORT=3001

# GitHub (server-only — never expose to the browser)
GITHUB_TOKEN=
GITHUB_USERNAME=thalitapaiva
GITHUB_CACHE_TTL_SECONDS=2700

# Email (Resend or SMTP / console for local)
EMAIL_PROVIDER=console
EMAIL_FROM=portfolio@example.com
EMAIL_TO=contact@example.com
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Cloudflare Turnstile (optional)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# LinkedIn OIDC (optional future integration — not required for public portfolio)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3001/api/auth/linkedin/callback

# Contact rate limit
CONTACT_RATE_LIMIT_TTL_MS=60000
CONTACT_RATE_LIMIT_MAX=5
